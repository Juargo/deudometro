{
  "name": "deudometro",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev:backend": "pnpm --filter @deudometro/backend dev",
    "dev:frontend": "pnpm --filter @deudometro/frontend dev",
    "build:backend": "pnpm --filter @deudometro/backend build",
    "build:frontend": "pnpm --filter @deudometro/frontend build",
    "db:migrate": "pnpm --filter @deudometro/backend db:migrate",
    "db:generate": "pnpm --filter @deudometro/backend db:generate",
    "db:studio": "pnpm --filter @deudometro/backend db:studio",
    "test": "pnpm --filter @deudometro/backend test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  }
}
