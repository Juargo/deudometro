# ─── API Backend ───
# Local: http://localhost:3001
# Vercel: configurar en dashboard → Environment Variables
#         Poner la URL de Render, ej: https://deudometro-api.onrender.com
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ─── Supabase (public keys — safe to expose) ───
# Vercel: configurar en dashboard → Environment Variables
NUXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
