generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  owner
  editor
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum DebtType {
  credit_card
  consumer_loan
  mortgage
  informal_lender
}

enum DebtStatus {
  active
  paid_off
  frozen
}

enum StrategyType {
  avalanche
  snowball
  hybrid
  crisis_first
  guided_consolidation
}

enum PlanStatus {
  active
  completed
  superseded
}

enum MilestoneType {
  debt_paid_off
  first_payment
  plan_on_track
  total_reduced_25pct
  total_reduced_50pct
  total_reduced_75pct
}

model FinancialSpace {
  id        String   @id @default(uuid())
  name      String
  currency  String   @default("CLP")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     FinancialSpaceMember[]
  profiles    UserProfile[]
  invitations Invitation[]
  debts       Debt[]
  debtPlans   DebtPlan[]
  payments    Payment[]
  milestones  Milestone[]

  @@map("financial_spaces")
}

model UserProfile {
  id               String   @id @default(uuid())
  supabaseUserId   String   @unique @map("supabase_user_id")
  email            String
  displayName      String   @map("display_name")
  monthlyIncome      Decimal  @default(0) @map("monthly_income") @db.Decimal(15, 2)
  availableCapital   Decimal  @default(0) @map("available_capital") @db.Decimal(15, 2)
  monthlyAllocation  Decimal  @default(0) @map("monthly_allocation") @db.Decimal(15, 2)
  fixedExpenses      Json?    @map("fixed_expenses")
  reservePercentage  Decimal  @default(10) @map("reserve_percentage") @db.Decimal(5, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  financialSpaceId String         @map("financial_space_id")
  financialSpace   FinancialSpace @relation(fields: [financialSpaceId], references: [id])

  @@index([financialSpaceId])
  @@map("user_profiles")
}

model FinancialSpaceMember {
  id               String     @id @default(uuid())
  userId           String     @map("user_id")
  role             MemberRole
  joinedAt         DateTime   @default(now()) @map("joined_at")
  invitedByUserId  String?    @map("invited_by_user_id")

  financialSpaceId String         @map("financial_space_id")
  financialSpace   FinancialSpace @relation(fields: [financialSpaceId], references: [id])

  @@unique([financialSpaceId, userId])
  @@index([userId])
  @@map("financial_space_members")
}

model Invitation {
  id              String           @id @default(uuid())
  email           String
  tokenHash       String           @unique @map("token_hash")
  status          InvitationStatus @default(pending)
  expiresAt       DateTime         @map("expires_at")
  invitedByUserId String           @map("invited_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")

  financialSpaceId String         @map("financial_space_id")
  financialSpace   FinancialSpace @relation(fields: [financialSpaceId], references: [id])

  @@index([financialSpaceId])
  @@map("invitations")
}

model Debt {
  id                  String     @id @default(uuid())
  financialSpaceId    String     @map("financial_space_id")
  createdByUserId     String     @map("created_by_user_id")
  label               String
  debtType            DebtType   @map("debt_type")
  lenderName          String     @map("lender_name")
  originalBalance     Decimal    @map("original_balance") @db.Decimal(15, 2)
  remainingBalance    Decimal    @map("remaining_balance") @db.Decimal(15, 2)
  monthlyInterestRate Decimal    @map("monthly_interest_rate") @db.Decimal(7, 4)
  minimumPayment      Decimal    @map("minimum_payment") @db.Decimal(15, 2)
  paymentDueDay       Int        @map("payment_due_day")
  cutoffDay           Int?       @map("cutoff_day")
  isShared            Boolean    @default(false) @map("is_shared")
  status              DebtStatus @default(active)
  metadata            Json?
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  financialSpace FinancialSpace @relation(fields: [financialSpaceId], references: [id])
  payments       Payment[]

  @@index([financialSpaceId])
  @@index([financialSpaceId, status])
  @@map("debts")
}

model DebtPlan {
  id                       String       @id @default(uuid())
  financialSpaceId         String       @map("financial_space_id")
  strategyType             StrategyType @map("strategy_type")
  status                   PlanStatus   @default(active)
  monthlyIncomeSnapshot    Decimal      @map("monthly_income_snapshot") @db.Decimal(15, 2)
  availableCapitalSnapshot Decimal      @map("available_capital_snapshot") @db.Decimal(15, 2)
  totalFixedCostsSnapshot  Decimal      @map("total_fixed_costs_snapshot") @db.Decimal(15, 2)
  reservePercentage        Decimal      @map("reserve_percentage") @db.Decimal(5, 2)
  monthlyBudget            Decimal      @map("monthly_budget") @db.Decimal(15, 2)
  aiAnalysis               Json?        @map("ai_analysis")
  createdByUserId          String       @map("created_by_user_id")
  aiPrompt                 Json?        @map("ai_prompt")
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  financialSpace FinancialSpace @relation(fields: [financialSpaceId], references: [id])
  actions        PlanAction[]

  @@index([financialSpaceId])
  @@index([financialSpaceId, status])
  @@map("debt_plans")
}

model PlanAction {
  id              String   @id @default(uuid())
  debtPlanId      String   @map("debt_plan_id")
  debtId          String   @map("debt_id")
  debtLabel       String   @map("debt_label")
  debtType        DebtType @map("debt_type")
  month           Int
  paymentAmount   Decimal  @map("payment_amount") @db.Decimal(15, 2)
  principalAmount Decimal  @map("principal_amount") @db.Decimal(15, 2)
  interestAmount  Decimal  @map("interest_amount") @db.Decimal(15, 2)
  runningBalance  Decimal  @map("running_balance") @db.Decimal(15, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  debtPlan DebtPlan @relation(fields: [debtPlanId], references: [id])

  @@index([debtPlanId])
  @@index([debtId])
  @@map("plan_actions")
}

model Payment {
  id               String   @id @default(uuid())
  debtId           String   @map("debt_id")
  financialSpaceId String   @map("financial_space_id")
  recordedByUserId String   @map("recorded_by_user_id")
  amount           Decimal  @db.Decimal(15, 2)
  principalAmount  Decimal  @map("principal_amount") @db.Decimal(15, 2)
  interestAmount   Decimal  @map("interest_amount") @db.Decimal(15, 2)
  paidAt           DateTime @map("paid_at")
  idempotencyKey   String   @unique @map("idempotency_key")
  createdAt        DateTime @default(now()) @map("created_at")

  financialSpace FinancialSpace @relation(fields: [financialSpaceId], references: [id])
  debt           Debt           @relation(fields: [debtId], references: [id])

  @@index([debtId])
  @@index([financialSpaceId])
  @@index([recordedByUserId])
  @@map("payments")
}

model Milestone {
  id               String        @id @default(uuid())
  financialSpaceId String        @map("financial_space_id")
  milestoneType    MilestoneType @map("milestone_type")
  debtId           String?       @map("debt_id")
  message          String
  acknowledgedAt   DateTime?     @map("acknowledged_at")
  createdAt        DateTime      @default(now()) @map("created_at")

  financialSpace FinancialSpace @relation(fields: [financialSpaceId], references: [id])

  @@index([financialSpaceId])
  @@index([debtId])
  @@map("milestones")
}
